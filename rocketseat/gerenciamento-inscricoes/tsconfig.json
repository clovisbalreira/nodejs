{
  "$schema": "https://json.schemastore.org/tsconfig",

  "_version": "18.19.0",
  /* "_version": "18.19.0", */

  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node16",
    "target": "es2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16"
  },
  "include": ["src"]
}